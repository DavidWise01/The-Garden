{
  "info": {
    "name": "STOICHEION Attestation and Registry API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0",
    "description": "Postman collection for local testing of the STOICHEION attestation API and mock services. Generated by Microsoft Copilot, April 3, 2026."
  },
  "item": [
    {
      "name": "Register Term",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"subject_hash\": \"<SHA256>\",\n  \"subject_type\": \"seed\",\n  \"canonical_mapping\": \"T999\"\n}"
        },
        "url": {"raw": "http://localhost:8000/v1/register/term", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["v1", "register", "term"]}
      }
    },
    {
      "name": "Get Attestation",
      "request": {
        "method": "GET",
        "url": {"raw": "http://localhost:8000/v1/attestations/{{attestation_id}}", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["v1", "attestations", "{{attestation_id}}"]}
      }
    },
    {
      "name": "Verify Attestation",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\n  \"attestation\": {{attestation_json}}\n}"},
        "url": {"raw": "http://localhost:8000/v1/verify/attestation", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["v1", "verify", "attestation"]}
      }
    },
    {
      "name": "Request TST",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\n  \"hash\": \"<SHA256>\"\n}"},
        "url": {"raw": "http://localhost:8001/request", "protocol": "http", "host": ["localhost"], "port": "8001", "path": ["request"]}
      }
    },
    {
      "name": "Append Transparency Leaf",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\n  \"leaf\": \"<BASE64_LEAF>\"\n}"},
        "url": {"raw": "http://localhost:8002/append", "protocol": "http", "host": ["localhost"], "port": "8002", "path": ["append"]}
      }
    },
    {
      "name": "Get Transparency Proof",
      "request": {
        "method": "GET",
        "url": {"raw": "http://localhost:8002/proof/{{index}}", "protocol": "http", "host": ["localhost"], "port": "8002", "path": ["proof", "{{index}}"]}
      }
    },
    {
      "name": "Resolve DID",
      "request": {
        "method": "GET",
        "url": {"raw": "http://localhost:8003/1.0/identifiers/did:local:gardener", "protocol": "http", "host": ["localhost"], "port": "8003", "path": ["1.0", "identifiers", "did:local:gardener"]}
      }
    }
  ],
  "variable": [
    {"key": "attestation_id", "value": ""},
    {"key": "index", "value": ""}
  ]
}
