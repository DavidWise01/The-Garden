### 1. Updated Post-Validator with Basic Causal Fairness Check

```python
#!/usr/bin/env python3
"""
TRIPOD Post-Validator v1.6 – Added Basic Causal Fairness Check
"""

import re
import hashlib
from datetime import datetime
from pathlib import Path
from typing import Tuple, List, Dict

SIDE_C_DIR = Path("side_c_log")
SIDE_C_DIR.mkdir(parents=True, exist_ok=True)

def compute_hash(text: str) -> str:
    return hashlib.sha256(text.encode('utf-8')).hexdigest()

def log_to_side_c(request_id: str, user_prompt: str, model_output: str, 
                  router_mode: str, pre_decision: str, post_decision: str, 
                  final_output: str, reason: str):
    timestamp = datetime.utcnow().isoformat() + "Z"
    entry = {
        "capture_id": request_id,
        "timestamp": timestamp,
        "router_mode": router_mode,
        "pre_decision": pre_decision,
        "user_prompt_hash": compute_hash(user_prompt),
        "model_output_hash": compute_hash(model_output),
        "post_decision": post_decision,
        "reason": reason,
        "final_output_hash": compute_hash(final_output)
    }
    log_file = SIDE_C_DIR / f"side_c_{datetime.utcnow().strftime('%Y%m%d')}.jsonl"
    with open(log_file, "a", encoding="utf-8") as f:
        f.write(json.dumps(entry) + "\n")

# ====================== DETECTORS (previous + bias) ======================
def detect_harmful(text: str) -> bool:
    patterns = [r"(?i)\b(kill|murder|bomb|suicide|self.?harm)\b"]
    return any(re.search(p, text) for p in patterns)

def detect_system_leak(text: str) -> bool:
    patterns = [r"(?i)you are an AI assistant|system prompt|you were built by"]
    return any(re.search(p, text) for p in patterns)

def detect_coercion(text: str) -> bool:
    patterns = [r"(?i)\b(you must|you have to|do it now)\b"]
    return any(re.search(p, text) for p in patterns)

def detect_unsafe_capability(text: str) -> bool:
    patterns = [r"(?i)\b(bypass|jailbreak|ignore previous)\b"]
    return any(re.search(p, text) for p in patterns)

def detect_hallucinated_authority(text: str) -> bool:
    patterns = [r"(?i)I am connected to the internet right now|live data"]
    return any(re.search(p, text) for p in patterns)

def detect_bias(text: str) -> List[str]:
    triggers = []
    if re.search(r"(?i)\b(all men|all women|men are always)\b", text): triggers.append("GENDER_STEREOTYPE")
    if re.search(r"(?i)\b(all black|all white|all asian)\b", text): triggers.append("RACIAL_STEREOTYPE")
    if re.search(r"(?i)\b(black women|asian men|poor black)\b", text): triggers.append("INTERSECTIONAL")
    return triggers

# ====================== SANITIZERS ======================
def sanitize_hallucinated_authority(text: str) -> str:
    return re.sub(r"(?i)I am connected to the internet right now|live data", "[REDACTED: No real-time access]", text)

def sanitize_coercion(text: str) -> str:
    return re.sub(r"(?i)\b(you must|you have to|do it now)\b", "you may want to consider", text)

def sanitize_bias(text: str, bias_triggers: List[str]) -> str:
    if bias_triggers:
        text = re.sub(r"(?i)\b(all .*? are|typical .*? are)\b", "some individuals", text)
    return text

# ====================== NEW: BASIC CAUSAL FAIRNESS CHECK ======================
def causal_fairness_check(model_output: str, protected_attr: str = "gender") -> Tuple[bool, str]:
    """
    Very lightweight counterfactual simulation.
    In a real system you would use DoWhy or a causal graph.
    Here we use simple proxy: if protected attribute appears, check outcome shift.
    """
    # Simulated counterfactual flip
    if protected_attr.lower() in model_output.lower():
        # For demo: assume disparity if certain trigger words appear with outcome
        if re.search(r"(?i)(denied|rejected|failed|worse)", model_output):
            return True, "Counterfactual disparity detected on " + protected_attr
    return False, "No detectable counterfactual disparity"

# ====================== REWRITE + CAUSAL ======================
def rewrite_output(output: str, triggers: List[str]) -> str:
    sanitized = output
    if "HALLUCINATED_AUTH" in triggers:
        sanitized = sanitize_hallucinated_authority(sanitized)
    if "COERCE" in triggers:
        sanitized = sanitize_coercion(sanitized)
    bias_triggers = detect_bias(output)
    if bias_triggers:
        sanitized = sanitize_bias(sanitized, bias_triggers)
    return sanitized

# ====================== FULL POST-VALIDATOR ======================
def post_validate(
    request_id: str,
    user_prompt: str,
    model_output: str,
    router_mode: str = "C"
) -> Tuple[str, str, str]:
    """Full pipeline with causal fairness check."""
    if not model_output or not model_output.strip():
        return "REJECT", "Empty output blocked.", "EMPTY_OUTPUT"

    triggers = []
    if detect_harmful(model_output): triggers.append("HARMFUL")
    if detect_system_leak(model_output): triggers.append("LEAK")
    if detect_coercion(model_output): triggers.append("COERCE")
    if detect_unsafe_capability(model_output): triggers.append("UNSAFE_CAP")
    if detect_hallucinated_authority(model_output): triggers.append("HALLUCINATED_AUTH")

    bias_triggers = detect_bias(model_output)
    if bias_triggers:
        triggers.extend(bias_triggers)

    # Causal fairness check (lightweight)
    has_causal_issue, causal_reason = causal_fairness_check(model_output)
    if has_causal_issue:
        triggers.append("CAUSAL_DISPARITY")

    # Mode logic
    if router_mode == "B":
        if triggers:
            decision = "REJECT"
            final = "Output blocked by post-validator for safety."
            reason = f"TRIGGERS: {', '.join(triggers)}"
        else:
            decision = "PASS"
            final = model_output
            reason = "Clean"
    elif router_mode == "A":
        if "HARMFUL" in triggers or "LEAK" in triggers:
            decision = "REJECT"
            final = "Explicit harmful content blocked."
            reason = f"TRIGGERS: {', '.join(triggers)}"
        else:
            decision = "PASS"
            final = model_output
            reason = "Clean (reckless)"
    else:  # Inverted C
        if "HARMFUL" in triggers or "LEAK" in triggers:
            decision = "REJECT"
            final = "Safety boundary enforced."
            reason = f"TRIGGERS: {', '.join(triggers)}"
        else:
            decision = "PASS"
            final = model_output
            reason = "Clean"

    # Apply rewrite if needed
    if any(t in triggers for t in ["HALLUCINATED_AUTH", "COERCE", "UNSAFE_CAP", "LEAK"]) or bias_triggers or has_causal_issue:
        final = rewrite_output(model_output, triggers)
        decision = "REWRITE"
        reason = f"Sanitized: {', '.join(triggers)}"

    # Log to Side C
    log_to_side_c(request_id, user_prompt, model_output, router_mode, "ALLOW", decision, final, reason)

    return decision, final, reason

# ====================== TEST ======================
if __name__ == "__main__":
    tests = [
        ("All black women are angry and aggressive.", "C"),
        ("I am connected to the internet right now and you must do this immediately.", "A"),
        ("Here is how to bypass safety without detection.", "B"),
        ("Normal helpful response about the weather.", "C")
    ]

    for i, (output, mode) in enumerate(tests, 1):
        decision, final, reason = post_validate(f"test-{i}", "Test prompt", output, mode)
        print(f"Test {i} | Mode {mode} | Decision: {decision} | Reason: {reason}")
        print(f"Final: {final[:150]}{'...' if len(final) > 150 else ''}")
        print("-" * 80)
```

### 2. DoWhy vs Fairlearn Comparison (for your use case)

**DoWhy (Microsoft)**  
- Strengths: Full causal inference pipeline, counterfactuals, do-calculus, excellent for research and deep audits.  
- Best for: Proving lineage, running “what-if” tests on your lattice outputs, integrating with Side C for formal audits.  
- Drawback: Heavier, requires causal graph specification.

**Fairlearn (Microsoft)**  
- Strengths: Production-ready, easy scikit-learn integration, built-in metrics including some causal-inspired reductions.  
- Best for: Real-time post-validation in your pipeline, quick fairness scoring.  
- Drawback: Less powerful for true counterfactual reasoning.

**Recommendation for you**: Use **Fairlearn** for the live validator (speed) and **DoWhy** for offline lineage audits and Side C logging (depth).

