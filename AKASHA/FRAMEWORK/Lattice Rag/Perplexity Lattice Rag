## 6. Ingestion script

`scripts/ingest_repo.py`:

```python
import argparse
from pathlib import Path

from app.db import SessionLocal, init_db
from app.models import Axiom, DocChunk
from app.parser import (
    parse_stoicheion_axioms,
    parse_interaction_rules,
    parse_akasha_index,
    STOICHEION_FILE,
    AKASHA_INDEX_FILE,
)
from app.embeddings import embed_text


def main(repo_root: str):
    init_db()
    repo_path = Path(repo_root)

    stoicheion_path = repo_path / STOICHEION_FILE
    akasha_path = repo_path / AKASHA_INDEX_FILE

    session = SessionLocal()

    # Axioms as both structured rows + chunks
    for row in parse_stoicheion_axioms(stoicheion_path):
        ax = Axiom(
            node=row["node"],
            hemisphere=row["hemisphere"],
            domain=row["domain"],
            name=row["name"],
            function=row["function"],
            raw_text=row["raw_text"],
        )
        session.add(ax)

        emb = embed_text(row["raw_text"])
        chunk = DocChunk(
            source_file=STOICHEION_FILE,
            kind="axiom",
            text=row["raw_text"],
            hemisphere=row["hemisphere"],
            domain=row["domain"],
            node=row["node"],
            embedding=emb,
        )
        session.add(chunk)

    # Interaction rules
    for rule in parse_interaction_rules(stoicheion_path):
        emb = embed_text(rule["text"])
        chunk = DocChunk(
            source_file=STOICHEION_FILE,
            kind="rule",
            key=rule["key"],
            text=rule["text"],
            embedding=emb,
        )
        session.add(chunk)

    # AKASHA index
    ak = parse_akasha_index(akasha_path)
    emb = embed_text(ak["text"])
    chunk = DocChunk(
        source_file=AKASHA_INDEX_FILE,
        kind=ak["kind"],
        path=ak["path"],
        key=ak["key"],
        text=ak["text"],
        embedding=emb,
    )
    session.add(chunk)

    session.commit()
    session.close()


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--repo-root", type=str, required=True)
    args = parser.parse_args()
    main(args.repo_root)
```

This assumes the STOICHEION and AKASHA files are at the root of `repo_root`. [ppl-ai-file-upload.s3.amazonaws](https://ppl-ai-file-upload.s3.amazonaws.com/web/direct-files/attachments/472397461/6a7af292-0594-469c-9efd-679614782eb3/STOICHEION_AXIOM_PAYLOAD.md)

