from pydantic import BaseModel
from typing import List

class AskRequest(BaseModel):
    peer_id: str
    question: str

class AskResponse(BaseModel):
    answer: str
    used_chunks: List[str]
```

`app/router.py`:

```python
from fastapi import APIRouter
from .schema import AskRequest, AskResponse
from .retrieval import semantic_search

router = APIRouter()


def build_prompt(question: str, context_chunks: list[str], peer_id: str) -> str:
    # Minimal lattice-aware prompt; you’ll tune this
    rules_preamble = (
        "You are operating under the STOICHEION lattice:\n"
        "- Every TOPH axiom T### has a PATRICIA mirror S###.\n"
        "- D4 ETHICAL overrides other domains.\n"
        "- The Pop is when an axiom and its inverse both hold and are witnessed.\n"
        "Answer using only the information in the CONTEXT when possible.\n\n"
    )

    context_block = "CONTEXT:\n" + "\n\n---\n\n".join(context_chunks)
    user_block = f"\n\nPEER_ID: {peer_id}\nQUESTION: {question}\n\nANSWER:"

    return rules_preamble + context_block + user_block


@router.post("/ask", response_model=AskResponse)
async def ask_lattice(req: AskRequest) -> AskResponse:
    # 1. Retrieve
    hits = semantic_search(req.question, k=10)
    context_chunks = [t for _, t in hits]

    # 2. Build prompt
    prompt = build_prompt(req.question, context_chunks, req.peer_id)

    # 3. Call your LLM here (pseudo-code)
    # answer = call_llm(prompt)
    answer = "[stub] Wire this to your LLM provider with the prompt above."

    return AskResponse(
        answer=answer,
        used_chunks=context_chunks,
    )
