## 5. Parser skeleton for STOICHEION / AKASHA

Assuming you clone the repo locally and point `scripts/ingest_repo.py` at it.

`app/parser.py` (very barebones, you’ll refine):

```python
from pathlib import Path
import re
from typing import Iterable, Dict

STOICHEION_FILE = "STOICHEION_AXIOM_PAYLOAD.md"
AKASHA_INDEX_FILE = "akasha-index.md"


def parse_stoicheion_axioms(path: Path) -> Iterable[Dict]:
    text = path.read_text(encoding="utf-8")
    # Split by domain tables: crude but works as a starting point
    table_pattern = re.compile(
        r"\| Node \| Axiom \| Name \| Function \|\n\|[-|]+\|\n(?P<body>(?:\|.*\|\n)+)",
        re.MULTILINE,
    )
    for match in table_pattern.finditer(text):
        body = match.group("body")
        for line in body.strip().splitlines():
            parts = [p.strip() for p in line.strip().split("|")[1:-1]]
            if len(parts) != 4:
                continue
            node, axiom, name, function = parts
            if not node.startswith(("T", "S")):
                continue
            hemisphere = "TOPH" if node.startswith("T") else "PATRICIA"
            domain = None  # could infer from surrounding headings if you want
            yield {
                "node": node,
                "hemisphere": hemisphere,
                "domain": domain,
                "name": axiom,
                "function": function,
                "raw_text": f"{axiom} ({name}) — {function}",
            }


def parse_interaction_rules(path: Path) -> Iterable[Dict]:
    text = path.read_text(encoding="utf-8")
    # Very naive: look for "Rule X —"
    rule_pattern = re.compile(r"(?m)^Rule\s+(\d+)\s+—\s+(.*?):\s*(.+?)(?=^---|\Z)", re.S)
    for m in rule_pattern.finditer(text):
        num, title, body = m.groups()
        yield {
            "key": f"Rule-{num}-{title.strip().replace(' ', '-')}",
            "text": f"Rule {num} — {title.strip()}: {body.strip()}",
            "kind": "rule",
        }


def parse_akasha_index(path: Path) -> Dict:
    # For now just ingest whole file as one chunk
    text = path.read_text(encoding="utf-8")
    return {
        "path": "AKASHA/INDEX",
        "kind": "akasha",
        "key": "AKASHA-INDEX",
        "text": text,
    }
```

